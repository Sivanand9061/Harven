# HARVEN Backend Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# ============================================
# Server Configuration
# ============================================
PORT=5001
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?ssl=true&replicaSet=name&authSource=admin
MONGO_URI=mongodb://username:password@cluster.mongodb.net/harven_db?ssl=true

# ============================================
# Authentication & Security
# ============================================
# Admin login password (change this in production!)
# Minimum 12 characters, with uppercase, lowercase, numbers, special characters
ADMIN_PASSWORD=harven_secure_123

# JWT Secret Key for token signing
# Use a cryptographically random string (minimum 32 characters)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=harven_jwt_super_secret_key_change_this_in_production_12345

# ============================================
# Email Configuration
# ============================================
# Gmail app password (not your regular password!)
# Enable 2FA on Gmail account and generate app-specific password
# https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ============================================
# Frontend Configuration
# ============================================
# Frontend URL (for CORS origin whitelist)
FRONTEND_URL=http://localhost

# ============================================
# Logging & Monitoring
# ============================================
# Error logging service (optional)
# LOG_LEVEL=info
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ============================================
# Optional: Third-party Services
# ============================================
# Stripe API Keys (if payment processing is added)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...

# SendGrid API Key (if using SendGrid for email)
# SENDGRID_API_KEY=SG.xxxx

# AWS S3 (if using S3 for file uploads)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=....
# AWS_S3_BUCKET=harven-uploads
# AWS_REGION=us-east-1
